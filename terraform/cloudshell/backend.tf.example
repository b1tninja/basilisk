# Optional remote state for team/CI deploys.
# Committed backend.tf enables the azurerm backend; scripts/terraform-init.sh writes backend.hcl at init time.
#
# One-time bootstrap (existing stack — uses basiliskdevstore):
#   az login
#   clientId=$(az ad sp list --display-name basilisk-github-deploy --query "[0].appId" -o tsv)
#   GITHUB_SP_CLIENT_ID="$clientId" bash scripts/bootstrap-tfstate.sh --use-app-storage
#
# Greenfield dedicated tfstate account:
#   bash scripts/bootstrap-tfstate.sh
#
# Migrate existing local state:
#   cd terraform/cloudshell && terraform init -migrate-state -backend-config=backend.hcl -reconfigure

terraform {
  backend "azurerm" {}
}

# backend.hcl (gitignored, generated by scripts/terraform-init.sh):
# resource_group_name  = "basilisk-dev-rg"
# storage_account_name = "basiliskdevstore"
# container_name       = "tfstate"
# key                  = "basilisk-dev.tfstate"
# use_azuread_auth     = true
