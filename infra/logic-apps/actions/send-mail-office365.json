{
  "type": "ApiConnection",
  "inputs": {
    "host": {
      "connection": {
        "name": "@parameters('$connections')['office365']['connectionId']"
      }
    },
    "method": "post",
    "path": "/v2/Mail",
    "body": {
      "To": "@{triggerBody()?['To']}",
      "Subject": "@{triggerBody()?['Subject']}",
      "Body": "@{triggerBody()?['Body']}"
    }
  }
}
