{
  "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "mailProvider": {
      "type": "String",
      "defaultValue": "office365",
      "allowedValues": ["office365", "gmail"]
    }
  },
  "triggers": {
    "When_sendtoken_message": {
      "type": "ServiceBus",
      "inputs": {
        "queueName": "sendtoken-events",
        "connection": {
          "name": "@parameters('$connections')['servicebus']['connectionId']"
        }
      }
    }
  },
  "actions": {
    "Parse_message": {
      "type": "ParseJson",
      "inputs": {
        "content": "@triggerBody()",
        "schema": { "type": "object" }
      },
      "runAfter": {}
    },
    "Send_token_email": {
      "type": "Switch",
      "expression": "@parameters('mailProvider')",
      "cases": {
        "office365": {
          "case": "office365",
          "actions": {
            "Send_O365": {
              "type": "ApiConnection",
              "inputs": {
                "host": {
                  "connection": {
                    "name": "@parameters('$connections')['office365']['connectionId']"
                  }
                },
                "method": "post",
                "path": "/v2/Mail",
                "body": {
                  "To": "@body('Parse_message')?['email']",
                  "Subject": "OpenPGP HKP sendtoken",
                  "Body": "@string(body('Parse_message')?['json_ld'])",
                  "Attachments": [
                    {
                      "Name": "sendtoken.jsonld",
                      "ContentBytes": "@base64(string(body('Parse_message')?['json_ld']))"
                    }
                  ]
                }
              }
            }
          }
        },
        "gmail": {
          "case": "gmail",
          "actions": {
            "Send_Gmail": {
              "type": "ApiConnection",
              "inputs": {
                "host": {
                  "connection": {
                    "name": "@parameters('$connections')['gmail']['connectionId']"
                  }
                },
                "method": "post",
                "path": "/v2/Mail",
                "body": {
                  "To": "@body('Parse_message')?['email']",
                  "Subject": "OpenPGP HKP sendtoken",
                  "Body": "@string(body('Parse_message')?['json_ld'])"
                }
              }
            }
          }
        }
      },
      "runAfter": { "Parse_message": ["Succeeded"] }
    }
  }
}
